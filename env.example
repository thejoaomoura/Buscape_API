# Configuração do servidor
PORT=5173
APP_URL=http://localhost:5173

# Firebase Admin SDK
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-project-id.iam.gserviceaccount.com

# Resend API
RESEND_API_KEY=re_sua_chave_aqui
# Domínio verificado no Resend -> permite enviar para qualquer destinatário.
# Sem domínio verificado, use onboarding@resend.dev (só envia para o e-mail da conta).
EMAIL_FROM=BuscapéAPI <noreply@atroxweb.com.br>

# Vercel (para produção)
VERCEL=false

